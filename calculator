#include <LiquidCrystal.h>
int rs=7;
int en=8;
int d4=9;
int d5=10;
int d6=11;
int d7=12;
float num1;
float num2;
float ans;
String op;
LiquidCrystal lcd(rs,en,d4,d5,d6,d7);
void setup() {

lcd.begin(16,2);
Serial.begin(9600);
}

void loop() {

lcd.setCursor(0,0);
lcd.print("input a number:");
while (Serial.available()==0){

}
num1=Serial.parseFloat();
lcd.clear();
lcd.setCursor(0,0);
lcd.print("input next number:");
while (Serial.available()==0){

}
num2=Serial.parseFloat();
lcd.clear();
lcd.setCursor(0,0);
lcd.print("input(+,-,/,*): ");
while (Serial.available()==0){

}
op=Serial.readString();
if(op=="+"){
  ans=num1+num2;
}else if(op=="-"){
  ans=num1-num2;
}else if (op=="*"){
  ans=num1*num2;
}else{
  ans=num1/num2;
}
lcd.clear();
lcd.setCursor(0,0);
lcd.print(num1);
lcd.print(op);
lcd.print(num2);
lcd.print("=");
lcd.print(ans);
lcd.setCursor(0,1);
lcd.print("Thank you");
delay(1000);
lcd.clear();
}
